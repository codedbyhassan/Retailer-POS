# Supabase Configuration (Optional - app works offline without it)
# Get these from https://supabase.com project settings
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Server Configuration
PORT=3001
NODE_ENV=development

# API Rate Limiting (configured in middleware/rateLimitMiddleware.js)
# Sync: 50 requests/minute per user
# Barcode: 10 requests/minute per user
# To change limits, edit the constants in rateLimitMiddleware.js and restart

# Barcode Lookup API (optional external service)
# Leave blank to use only local barcode search
# Get from https://www.barcodelookup.com/api/
BARCODE_API_KEY=your_barcode_api_key

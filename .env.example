# Frontend Configuration for Retailer-POS

# API Server Connection
# Point to your backend server (local development or production)
# Local: http://localhost:3001
# Production: https://your-api-domain.com
VITE_API_URL=http://localhost:3001

# Supabase Integration (Optional - app works offline without it)
# Get these from https://supabase.com project settings → API
# See docs/SUPABASE_SETUP.md for complete setup instructions
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Barcode Lookup API (Optional external service)
# Enables barcode lookup in POS when product not found locally
# Get from https://www.barcodelookup.com/api/
# Leave blank to use only local barcode search (no external API calls)
# Rate limited to 10 lookups/minute per user (configurable in server)
VITE_BARCODE_API_KEY=your_barcode_api_key

# App Metadata
VITE_APP_NAME=Retailer-POS
VITE_APP_VERSION=1.0.0
